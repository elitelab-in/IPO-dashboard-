{
  "cleanUrls": true,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**/*.{html,css,js,png,jpg,jpeg,svg,gif,ico}",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/frontend/assets/$1" },
    { "source": "/(.*)", "destination": "/backend/app.py" }
  ]
}
