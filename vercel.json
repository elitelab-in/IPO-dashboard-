{
  "cleanUrls": true,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**/*.{html,css,js,png,jpg,jpeg,svg,gif,ico}",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/app.py" },
    { "source": "/assets/(.*)", "destination": "/frontend/assets/$1" },
    { "source": "/", "destination": "/frontend/pages/index.html" },
    { "source": "/screener", "destination": "/frontend/pages/screener.html" },
    { "source": "/about", "destination": "/frontend/pages/about.html" },
    { "source": "/contact", "destination": "/frontend/pages/contact.html" },
    { "source": "/articles", "destination": "/frontend/pages/articles.html" },
    { "source": "/article", "destination": "/frontend/pages/article-detail.html" },
    { "source": "/privacy", "destination": "/frontend/pages/privacy.html" },
    { "source": "/terms", "destination": "/frontend/pages/terms.html" },
    { "source": "/refund-policy", "destination": "/frontend/pages/refund-policy.html" },
    { "source": "/fundamentals", "destination": "/frontend/pages/fundamentals.html" },
    { "source": "/economy", "destination": "/frontend/pages/economy.html" },
    { "source": "/intraday-manager", "destination": "/frontend/pages/intraday-manager.html" },
    { "source": "/login", "destination": "/frontend/pages/login.html" },
    { "source": "/register", "destination": "/frontend/pages/register.html" },
    { "source": "/pricing", "destination": "/frontend/pages/pricing.html" },
    { "source": "/dashboard", "destination": "/frontend/pages/dashboard.html" },
    { "source": "/sector-analysis", "destination": "/frontend/pages/sector-analysis.html" },
    { "source": "/block-deals", "destination": "/frontend/pages/block-deals.html" },
    { "source": "/author", "destination": "/frontend/pages/author.html" }
  ]
}
